{
  "manifest_version": 2,
  "name": "Tether",
  "version": "1.0.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "tether@simonreid.space",
      "strict_min_version": "109.0"
    }
  },
  "description": "Save links to your self-hosted Tether instance with tags.",
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon-48.svg",
      "96": "icons/icon-96.svg"
    },
    "default_title": "Save to Tether"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  }
}
